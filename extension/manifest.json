{
  "manifest_version": 3,
  "name": "DiskWala Link Extractor Bridge",
  "version": "3.0",
  "description": "Reads DiskWala page state invisibly and forwards download links.",
  "permissions": [],
  "host_permissions": [
    "https://diskwala.com/*",
    "https://*.diskwala.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://diskwala.com/app/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
